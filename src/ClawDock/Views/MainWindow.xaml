<Window x:Class="ClawDock.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ClawDock"
        Width="1200" Height="780"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 工具栏 ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="28" Height="28"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="ClawDock" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                </StackPanel>

                <!-- 控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnStart" Style="{StaticResource ToolbarButton}"
                            Click="BtnStart_Click" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M8 5V19L19 12Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="启动" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnStop" Style="{StaticResource ToolbarButton}"
                            Click="BtnStop_Click" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M6 6H18V18H6Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="停止" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnRestart" Style="{StaticResource ToolbarButton}"
                            Click="BtnRestart_Click" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M17.65 6.35A7.958 7.958 0 0 0 12 4C7.58 4 4.01 7.58 4.01 12S7.58 20 12 20c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="重启" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnOpenBrowser" Style="{StaticResource ToolbarButton}"
                            Click="BtnOpenBrowser_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="在浏览器中打开" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnConsole" Style="{StaticResource ToolbarButton}"
                            Click="BtnConsoleToggle_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v12zM7 10l4 3-4 3v-6zm6 5h4v2h-4v-2z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="控制台" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnUninstall" Style="{StaticResource ToolbarButton}"
                            Foreground="{StaticResource ErrorBrush}"
                            Click="BtnUninstall_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="卸载" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="VersionText" Text=""
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#555577" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="未运行"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 上方：页面内容 -->
            <Grid Grid.Row="0">

                <!-- WebView2 浏览器 -->
                <wv2:WebView2 x:Name="Browser"
                              Visibility="Collapsed"/>

                <!-- 未运行提示页 -->
                <Grid x:Name="PageNotRunning" Background="{StaticResource BgBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Assets/logo.png" Width="80" Height="80"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Gateway 未运行" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="点击「启动」按钮启动 ClawDock Gateway" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,28"/>
                        <Button Content="▶  启动 Gateway"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Center"
                                Click="BtnStart_Click"/>
                    </StackPanel>
                </Grid>

                <!-- 正在启动提示 -->
                <Grid x:Name="PageStarting" Visibility="Collapsed" Background="{StaticResource BgBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="正在启动 ClawDock Gateway..." FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Grid>

                <!-- WSL 初始化中提示 -->
                <Grid x:Name="PageInitializing" Visibility="Collapsed" Background="{StaticResource BgBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Assets/logo.png" Width="80" Height="80"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="正在初始化运行环境..." FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="InitStatusText" Text="正在启动 WSL 子系统，请稍候..."
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- 下方：日志控制台面板 -->
            <Border x:Name="ConsolePanel" Grid.Row="1" Visibility="Collapsed"
                    Background="#0A0A15"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Height="180">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 控制台标题栏 -->
                    <Border Grid.Row="0" Background="#12122A"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="10,0">
                            <TextBlock Text="Console" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="Clear" FontSize="11"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="BtnConsoleClear_Click" Padding="6,2"/>
                                <Button Content="✕" FontSize="12"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="BtnConsoleToggle_Click" Padding="6,2"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 日志内容 -->
                    <ScrollViewer x:Name="ConsoleScroll" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ConsoleText"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="12" Foreground="#A0C0A0"
                                   Margin="10,6" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
