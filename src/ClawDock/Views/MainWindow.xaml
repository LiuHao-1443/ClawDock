<Window x:Class="ClawDock.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ClawDock"
        Width="1200" Height="780"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 工具栏 ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="28" Height="28"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="ClawDock" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                </StackPanel>

                <!-- 控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnStart" Style="{StaticResource ToolbarButton}"
                            Click="BtnStart_Click" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M8 5V19L19 12Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="启动" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnStop" Style="{StaticResource ToolbarButton}"
                            Click="BtnStop_Click" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M6 6H18V18H6Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="停止" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnRestart" Style="{StaticResource ToolbarButton}"
                            Click="BtnRestart_Click" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M17.65 6.35A7.958 7.958 0 0 0 12 4C7.58 4 4.01 7.58 4.01 12S7.58 20 12 20c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="重启" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnOpenBrowser" Style="{StaticResource ToolbarButton}"
                            Click="BtnOpenBrowser_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="在浏览器中打开" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnConsole" Style="{StaticResource ToolbarButton}"
                            Click="BtnConsoleToggle_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v12zM7 10l4 3-4 3v-6zm6 5h4v2h-4v-2z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="控制台" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnSettings" Style="{StaticResource ToolbarButton}"
                            Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="15" Height="15" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="设置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnUninstall" Style="{StaticResource ToolbarButton}"
                            Foreground="{StaticResource ErrorBrush}"
                            Click="BtnUninstall_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="卸载" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="VersionText" Text=""
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ModelText" Text=""
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#555577" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="未运行"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 上方：页面内容 -->
            <Grid Grid.Row="0">

                <!-- WebView2 浏览器 -->
                <wv2:WebView2 x:Name="Browser"
                              Visibility="Collapsed"/>

                <!-- 未运行提示页 -->
                <Grid x:Name="PageNotRunning" Background="{StaticResource BgBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Assets/logo.png" Width="80" Height="80"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Gateway 未运行" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="点击「启动」按钮启动 ClawDock Gateway" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,28"/>
                        <Button Content="▶  启动 Gateway"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Center"
                                Click="BtnStart_Click"/>
                    </StackPanel>
                </Grid>

                <!-- 正在启动提示 -->
                <Grid x:Name="PageStarting" Visibility="Collapsed" Background="{StaticResource BgBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="正在启动 ClawDock Gateway..." FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Grid>

                <!-- WSL 初始化中提示 -->
                <Grid x:Name="PageInitializing" Visibility="Collapsed" Background="{StaticResource BgBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="/Assets/logo.png" Width="80" Height="80"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="正在初始化运行环境..." FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="InitStatusText" Text="正在启动 WSL 子系统，请稍候..."
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Grid>

                <!-- ===== 设置页 ===== -->
                <Grid x:Name="PageSettings" Visibility="Collapsed" Background="{StaticResource BgBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧 Tab 侧栏 -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 顶部：返回 + 标题 -->
                            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="12,12">
                                <Grid>
                                    <Button x:Name="BtnSettingsBack" Style="{StaticResource ToolbarButton}"
                                            Click="BtnSettingsBack_Click"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Padding="6,4">
                                        <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </Button>
                                    <TextBlock Text="设置" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Tab 列表 -->
                            <StackPanel Grid.Row="1" Margin="8,8,8,0">
                                <Button x:Name="TabModels" Style="{StaticResource ToolbarButton}"
                                        Click="TabModels_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="14,12" Margin="0,0,0,4"
                                        Content="模型配置" FontSize="15"/>

                                <Button x:Name="TabChannels" Style="{StaticResource ToolbarButton}"
                                        Click="TabChannels_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="14,12" Margin="0,0,0,4"
                                        Content="渠道配置" FontSize="15"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 右侧内容区 -->
                    <Grid Grid.Column="1">
                        <!-- 加载中/错误提示 -->
                        <Grid x:Name="SettingsLoading" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                             Foreground="{StaticResource AccentBrush}"
                                             Background="Transparent" BorderThickness="0"/>
                                <TextBlock Text="正在加载配置..." FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="SettingsError" Visibility="Collapsed"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="14" Margin="30,30"
                                   TextWrapping="Wrap"/>

                        <!-- ===== 模型配置 Tab ===== -->
                        <ScrollViewer x:Name="SettingsTabModels" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" Padding="30,24,30,30">
                            <StackPanel MaxWidth="600">
                                <TextBlock Text="模型配置" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="配置 AI 模型和 Provider" Style="{StaticResource FieldHint}"
                                           Margin="0,0,0,24"/>

                                <!-- 主模型 -->
                                <TextBlock Text="服务商" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CboProvider" Style="{StaticResource DarkComboBoxReadOnly}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItem}"/>
                                <TextBlock Text="选择模型服务商" Style="{StaticResource FieldHint}"
                                           Margin="0,4,0,12"/>

                                <TextBlock Text="模型" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CboPrimaryModel" Style="{StaticResource DarkComboBox}"
                                          ItemContainerStyle="{StaticResource DarkComboBoxItem}"/>
                                <TextBlock Text="用于对话的默认模型，可从列表选择或手动输入完整名称（如 openai/gpt-4o）" Style="{StaticResource FieldHint}"
                                           Margin="0,4,0,12"/>

                                <!-- 服务商 API Key -->
                                <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="PwdSelectedProviderKey" Style="{StaticResource DarkPasswordBox}"/>
                                    <TextBox x:Name="TxtSelectedProviderKey" Style="{StaticResource DarkTextBox}"
                                             Visibility="Collapsed"/>
                                    <Button x:Name="BtnToggleSelectedProviderKey" Grid.Column="1"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="显示" Click="BtnToggleSelectedProviderKey_Click"
                                            Padding="12,8" Margin="6,0,0,0" FontSize="12"/>
                                </Grid>
                                <TextBlock x:Name="TxtProviderApiKeyHint" Text="当前服务商的 API Key" Style="{StaticResource FieldHint}"
                                           Margin="0,4,0,20"/>

                                <!-- 备选模型 -->
                                <TextBlock Text="备选模型" Style="{StaticResource FieldLabel}"/>
                                <StackPanel x:Name="FallbackModelsList"/>
                                <Button x:Name="BtnAddFallback" Content="+ 添加备选模型"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnAddFallback_Click"
                                        HorizontalAlignment="Left" Padding="16,6"
                                        FontSize="12" Margin="0,6,0,20"/>

                                <!-- Provider 配置 -->
                                <TextBlock Text="自定义 Provider" Style="{StaticResource FieldLabel}" Margin="0,8,0,6"/>
                                <TextBlock Text="配置自定义模型提供商（如 OpenAI 兼容 API）"
                                           Style="{StaticResource FieldHint}" Margin="0,0,0,12"/>

                                <Border Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="20,16"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Provider 名称" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtProviderName" Style="{StaticResource DarkTextBox}"
                                                 Margin="0,0,0,12"/>

                                        <TextBlock Text="Base URL" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtProviderBaseUrl" Style="{StaticResource DarkTextBox}"
                                                 Margin="0,0,0,12"/>
                                        <TextBlock Text="例如: https://api.openai.com/v1" Style="{StaticResource FieldHint}"
                                                   Margin="0,-8,0,12"/>

                                        <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="PwdProviderApiKey" Style="{StaticResource DarkPasswordBox}"/>
                                            <Button x:Name="BtnToggleApiKey" Grid.Column="1"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Content="显示" Click="BtnToggleApiKey_Click"
                                                    Padding="12,8" Margin="6,0,0,0" FontSize="12"/>
                                        </Grid>
                                        <!-- Hidden TextBox for showing API key -->
                                        <TextBox x:Name="TxtProviderApiKeyVisible" Style="{StaticResource DarkTextBox}"
                                                 Visibility="Collapsed" Margin="0,-12,0,12"/>

                                        <TextBlock Text="API 类型" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="CboProviderApi" Style="{StaticResource DarkComboBox}"
                                                  IsEditable="False" Margin="0,0,0,12">
                                            <ComboBoxItem Content="openai" Style="{StaticResource DarkComboBoxItem}" IsSelected="True"/>
                                            <ComboBoxItem Content="anthropic" Style="{StaticResource DarkComboBoxItem}"/>
                                            <ComboBoxItem Content="google" Style="{StaticResource DarkComboBoxItem}"/>
                                        </ComboBox>

                                        <TextBlock Text="模型列表" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="每个模型需要 Name（显示名）和 ID（API 模型标识）"
                                                   Style="{StaticResource FieldHint}" Margin="0,0,0,8"/>
                                        <StackPanel x:Name="ProviderModelsList"/>
                                        <Button x:Name="BtnAddProviderModel" Content="+ 添加模型"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="BtnAddProviderModel_Click"
                                                HorizontalAlignment="Left" Padding="16,6"
                                                FontSize="12" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 保存按钮 + 状态 -->
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button x:Name="BtnSaveModels" Content="保存模型配置"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnSaveModels_Click"
                                            Padding="24,10"/>
                                    <TextBlock x:Name="TxtModelSaveStatus"
                                               VerticalAlignment="Center" Margin="16,0,0,0"
                                               FontSize="13"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ===== 渠道配置 Tab ===== -->
                        <ScrollViewer x:Name="SettingsTabChannels" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" Padding="30,24,30,30">
                            <StackPanel MaxWidth="600">
                                <TextBlock Text="渠道配置" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="配置消息渠道（飞书）"
                                           Style="{StaticResource FieldHint}" Margin="0,0,0,24"/>

                                <!-- 飞书 (Feishu) -->
                                <Border Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="20,16"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="飞书" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <CheckBox x:Name="ChkFeishuEnabled" Style="{StaticResource ToggleSwitch}"/>
                                        </StackPanel>
                                        <TextBlock Text="App ID" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="TxtFeishuAppId" Style="{StaticResource DarkTextBox}"
                                                 Margin="0,0,0,12"/>
                                        <TextBlock Text="App Secret" Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="PwdFeishuAppSecret" Style="{StaticResource DarkPasswordBox}"
                                                     Margin="0,0,0,12"/>
                                        <TextBlock Text="连接方式" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="CboFeishuConnectionMode" Style="{StaticResource DarkComboBoxReadOnly}"
                                                  ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                                                  SelectionChanged="CboFeishuConnectionMode_SelectionChanged"
                                                  Margin="0,0,0,12">
                                            <ComboBoxItem Content="websocket" IsSelected="True"/>
                                            <ComboBoxItem Content="webhook"/>
                                        </ComboBox>
                                        <StackPanel x:Name="PanelFeishuVerifyToken" Visibility="Collapsed">
                                            <TextBlock Text="Verify Token" Style="{StaticResource FieldLabel}"/>
                                            <PasswordBox x:Name="PwdFeishuVerifyToken" Style="{StaticResource DarkPasswordBox}"/>
                                            <TextBlock Text="Webhook 模式需要配置验证 Token"
                                                       Style="{StaticResource FieldHint}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- 配对批准 -->
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,16,0,0">
                                            <StackPanel>
                                                <TextBlock Text="用户配对" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="用户首次与机器人对话时会收到配对码，在此输入以批准访问"
                                                           Style="{StaticResource FieldHint}" Margin="0,0,0,10"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="TxtFeishuPairingCode" Style="{StaticResource DarkTextBox}"
                                                             VerticalContentAlignment="Center"/>
                                                    <Button x:Name="BtnFeishuPairingApprove" Grid.Column="1"
                                                            Content="批准" Style="{StaticResource PrimaryButton}"
                                                            Click="BtnFeishuPairingApprove_Click"
                                                            Padding="20,8" Margin="8,0,0,0"/>
                                                </Grid>
                                                <TextBlock x:Name="TxtFeishuPairingStatus"
                                                           FontSize="12" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Telegram (hidden) -->
                                <Border Visibility="Collapsed">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkTelegramEnabled" Style="{StaticResource ToggleSwitch}"/>
                                        <PasswordBox x:Name="PwdTelegramToken" Style="{StaticResource DarkPasswordBox}"/>
                                        <ComboBox x:Name="CboTelegramDmPolicy">
                                            <ComboBoxItem Content="allow" IsSelected="True"/>
                                        </ComboBox>
                                        <CheckBox x:Name="ChkTelegramStreaming" Style="{StaticResource ToggleSwitch}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Discord (hidden) -->
                                <Border Visibility="Collapsed">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkDiscordEnabled" Style="{StaticResource ToggleSwitch}"/>
                                        <PasswordBox x:Name="PwdDiscordToken" Style="{StaticResource DarkPasswordBox}"/>
                                        <TextBox x:Name="TxtDiscordMediaMaxMb" Style="{StaticResource DarkTextBox}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Slack (hidden) -->
                                <Border Visibility="Collapsed">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkSlackEnabled" Style="{StaticResource ToggleSwitch}"/>
                                        <PasswordBox x:Name="PwdSlackBotToken" Style="{StaticResource DarkPasswordBox}"/>
                                        <PasswordBox x:Name="PwdSlackAppToken" Style="{StaticResource DarkPasswordBox}"/>
                                    </StackPanel>
                                </Border>

                                <!-- WhatsApp (hidden) -->
                                <Border Visibility="Collapsed">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkWhatsAppEnabled" Style="{StaticResource ToggleSwitch}"/>
                                        <ComboBox x:Name="CboWhatsAppDmPolicy">
                                            <ComboBoxItem Content="allow" IsSelected="True"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- 保存按钮 + 状态 -->
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button x:Name="BtnSaveChannels" Content="保存渠道配置"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnSaveChannels_Click"
                                            Padding="24,10"/>
                                    <TextBlock x:Name="TxtChannelSaveStatus"
                                               VerticalAlignment="Center" Margin="16,0,0,0"
                                               FontSize="13"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

            </Grid>

            <!-- 下方：日志控制台面板 -->
            <Border x:Name="ConsolePanel" Grid.Row="1" Visibility="Collapsed"
                    Background="#0A0A15"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Height="180">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 控制台标题栏 -->
                    <Border Grid.Row="0" Background="#12122A"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="10,0">
                            <TextBlock Text="Console" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="Clear" FontSize="11"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="BtnConsoleClear_Click" Padding="6,2"/>
                                <Button Content="✕" FontSize="12"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="BtnConsoleToggle_Click" Padding="6,2"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 日志内容 -->
                    <ScrollViewer x:Name="ConsoleScroll" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ConsoleText"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="12" Foreground="#A0C0A0"
                                   Margin="10,6" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
