<Window x:Class="ClawDock.Views.InstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenClaw 安装向导"
        Width="780" Height="520"
        MinWidth="780" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧步骤导航栏 -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo 区域 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <Image Source="/Assets/logo.png" Width="36" Height="36"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="ClawDock" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="安装向导" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- 步骤列表 -->
                <StackPanel Grid.Row="1" Margin="0,10,0,0" x:Name="StepList">

                    <!-- Step 1 -->
                    <Border x:Name="Step1Indicator" Height="52" Cursor="Arrow">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="Step1Circle" Width="22" Height="22"
                                     Fill="{StaticResource AccentBrush}" Grid.Column="0"/>
                            <TextBlock x:Name="Step1Num" Text="1" Grid.Column="0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="Step1Label" Text="欢迎" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 2 -->
                    <Border x:Name="Step2Indicator" Height="52">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="Step2Circle" Width="22" Height="22"
                                     Fill="#2A2A45" Grid.Column="0"/>
                            <TextBlock x:Name="Step2Num" Text="2" Grid.Column="0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="Step2Label" Text="系统检测" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 3 -->
                    <Border x:Name="Step3Indicator" Height="52">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="Step3Circle" Width="22" Height="22"
                                     Fill="#2A2A45" Grid.Column="0"/>
                            <TextBlock x:Name="Step3Num" Text="3" Grid.Column="0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="Step3Label" Text="安装 WSL2" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 4 -->
                    <Border x:Name="Step4Indicator" Height="52">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="Step4Circle" Width="22" Height="22"
                                     Fill="#2A2A45" Grid.Column="0"/>
                            <TextBlock x:Name="Step4Num" Text="4" Grid.Column="0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="Step4Label" Text="安装 ClawDock" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 5 -->
                    <Border x:Name="Step5Indicator" Height="52">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="Step5Circle" Width="22" Height="22"
                                     Fill="#2A2A45" Grid.Column="0"/>
                            <TextBlock x:Name="Step5Num" Text="5" Grid.Column="0"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="Step5Label" Text="完成" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>
        </Border>

        <!-- 右侧内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 步骤内容（用 Visibility 控制哪个显示） -->
            <Grid Grid.Row="0" Margin="40,36,40,0">

                <!-- ===== Step 1: 欢迎 ===== -->
                <StackPanel x:Name="PageWelcome" Visibility="Visible">
                    <TextBlock Text="欢迎安装 ClawDock" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,28">
                        OpenClaw 是一款运行在您自己设备上的个人 AI 助手平台，支持接入
                        WhatsApp、Telegram、Slack 等主流消息平台。
                    </TextBlock>

                    <TextBlock Text="本向导将自动安装以下组件：" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                    <StackPanel Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}"
                                       FontSize="14" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="WSL2 — Windows 适用 Linux 子系统" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="OpenClaw 运行所依赖的 Linux 环境" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}"
                                       FontSize="14" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Node.js 22 LTS" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="OpenClaw 的运行时" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6">
                            <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}"
                                       FontSize="14" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="OpenClaw 平台" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="您的个人 AI 助手" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,24,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        安装需要管理员权限，部分步骤可能需要重启计算机。
                    </TextBlock>
                </StackPanel>

                <!-- ===== Step 2: 系统检测 ===== -->
                <StackPanel x:Name="PageCheck" Visibility="Collapsed">
                    <TextBlock Text="系统环境检测" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                    <Grid x:Name="CheckGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- Windows 版本 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Windows 版本" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="CheckWinVersionText" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="CheckWinVersionStatus" Grid.Row="0" Grid.Column="1"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Text="…"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <!-- 虚拟化 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="硬件虚拟化（VT-x）" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="WSL2 所需的处理器功能" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="CheckVirtStatus" Grid.Row="1" Grid.Column="1"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Text="…"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <!-- WSL2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="WSL2" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="已安装则跳过安装步骤" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="CheckWslStatus" Grid.Row="2" Grid.Column="1"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Text="…"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <!-- Ubuntu -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Ubuntu (WSL2 发行版)" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="ClawDock 运行环境" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="CheckUbuntuStatus" Grid.Row="3" Grid.Column="1"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Text="…"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>

                    <Border x:Name="CheckErrorBanner" Visibility="Collapsed"
                            Background="#2A0A0A" BorderBrush="{StaticResource ErrorBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,10,0,0">
                        <TextBlock x:Name="CheckErrorText" TextWrapping="Wrap" FontSize="13"
                                   Foreground="{StaticResource ErrorBrush}"/>
                    </Border>
                </StackPanel>

                <!-- ===== Step 3: 安装 WSL2 ===== -->
                <Grid x:Name="PageWsl" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="安装 WSL2" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <Border Grid.Row="1" Background="#0A0A15" CornerRadius="6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <ScrollViewer x:Name="WslLogScroll" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="WslLogText" FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="12" Foreground="#A0C0A0" Margin="12"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <Border x:Name="WslRebootBanner" Grid.Row="2" Visibility="Collapsed"
                            Background="#1A1A00" BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,12,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="13"
                                   Foreground="{StaticResource WarningBrush}">
                            ⚠ WSL2 安装完成，需要重启计算机。重启后请重新打开 ClawDock，安装将自动继续。
                        </TextBlock>
                    </Border>
                </Grid>

                <!-- ===== Step 4: 安装 ClawDock ===== -->
                <Grid x:Name="PageInstall" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="安装 ClawDock" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <Border Grid.Row="1" Background="#0A0A15" CornerRadius="6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <ScrollViewer x:Name="InstallLogScroll" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="InstallLogText" FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="12" Foreground="#A0C0A0" Margin="12"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ===== Step 5: 完成 ===== -->
                <StackPanel x:Name="PageDone" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="72" Height="72"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="安装完成！" FontSize="24" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="14" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,36">
                        OpenClaw 已成功安装在您的电脑上。
                        点击下方按钮开始使用。
                    </TextBlock>
                </StackPanel>

            </Grid>

            <!-- 底部操作栏 -->
            <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="40,16">
                <Grid>
                    <ProgressBar x:Name="InstallProgress" Height="3" VerticalAlignment="Top"
                                 Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnBack" Content="← 上一步"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnBack_Click" Visibility="Hidden"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnNext" Content="开始安装 →"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnNext_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
