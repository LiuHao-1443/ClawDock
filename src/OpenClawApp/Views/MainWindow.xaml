<Window x:Class="OpenClawApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="OpenClaw"
        Width="1200" Height="780"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 工具栏 ===== -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="28" Height="28"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="OpenClaw" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                </StackPanel>

                <!-- 控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnStart" Content="▶  启动"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnStart_Click" Margin="0,0,4,0"/>
                    <Button x:Name="BtnStop" Content="⏹  停止"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnStop_Click" Margin="0,0,4,0"/>
                    <Button x:Name="BtnRestart" Content="↺  重启"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnRestart_Click" Margin="0,0,4,0"/>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnOpenBrowser" Content="🔗  在浏览器中打开"
                            Style="{StaticResource ToolbarButton}"
                            Click="BtnOpenBrowser_Click"/>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0"/>

                    <Button x:Name="BtnUninstall" Content="🗑  卸载"
                            Style="{StaticResource ToolbarButton}"
                            Foreground="{StaticResource ErrorBrush}"
                            Click="BtnUninstall_Click"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="#555577" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="未运行"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="1">

            <!-- WebView2 浏览器 -->
            <wv2:WebView2 x:Name="Browser"
                          Visibility="Collapsed"/>

            <!-- 未运行提示页 -->
            <Grid x:Name="PageNotRunning" Background="{StaticResource BgBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="80" Height="80"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Gateway 未运行" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="点击「启动」按钮启动 OpenClaw Gateway" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,28"/>
                    <Button Content="▶  启动 Gateway"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center"
                            Click="BtnStart_Click"/>
                </StackPanel>
            </Grid>

            <!-- 正在启动提示 -->
            <Grid x:Name="PageStarting" Visibility="Collapsed" Background="{StaticResource BgBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="正在启动 OpenClaw Gateway..." FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="Transparent" BorderThickness="0"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Window>
