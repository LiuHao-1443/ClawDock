<Window x:Class="OpenClawApp.Views.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="卸载 OpenClaw"
        Width="560" Height="420"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="卸载 OpenClaw" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="以下操作将从您的电脑上完整移除 OpenClaw" FontSize="13" Margin="0,6,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- 选项 -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="卸载内容" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- 固定卸载项 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}"
                               FontSize="13" Width="20"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                        停止并移除 OpenClaw Gateway
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}"
                               FontSize="13" Width="20"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                        从 WSL2 中卸载 OpenClaw (npm uninstall -g)
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}"
                               FontSize="13" Width="20"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                        清理注册表启动项和安装状态
                    </TextBlock>
                </StackPanel>

                <!-- 分隔线 -->
                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,12,0,12"/>

                <!-- 可选：移除 Ubuntu -->
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ChkRemoveUbuntu" VerticalAlignment="Center" Margin="0,0,10,0"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel>
                        <TextBlock Text="同时移除 Ubuntu WSL2 发行版" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            将删除 WSL2 中的整个 Ubuntu 环境（不影响 WSL2 本身）
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 日志区（卸载时显示） -->
        <Border Grid.Row="2" Background="#0A0A15" CornerRadius="6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Visibility="Collapsed" x:Name="LogPanel">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="12" Foreground="#A0C0A0"
                           Margin="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- 底部按钮 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="取消"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnCancel_Click" Margin="0,0,12,0"/>
                <Button x:Name="BtnUninstall" Content="开始卸载"
                        Style="{StaticResource PrimaryButton}"
                        Background="#C0392B"
                        Click="BtnUninstall_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
